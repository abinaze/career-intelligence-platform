# Copy to .env.prod (same directory as docker-compose.prod.yml) and fill
# in real values. .env.prod is gitignored — never commit real secrets.

# ── Database & cache passwords (compose interpolates these into the
#    connection URLs it builds itself — see docker-compose.prod.yml) ──────────
POSTGRES_USER=cip_prod_user
POSTGRES_PASSWORD=
POSTGRES_DB=cip_db
REDIS_PASSWORD=

# ── Public URLs (used by nginx routing and CORS; NEXT_PUBLIC_* get baked
#    into the frontend build, so a value change here needs a rebuild) ─────────
FRONTEND_URL=https://your-domain.example.com
NEXT_PUBLIC_API_URL=https://your-domain.example.com/api/v1
NEXT_PUBLIC_APP_URL=https://your-domain.example.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ── Chat ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── BYOS OAuth brokers (all optional — each degrades to 503 on its
#    endpoints if unset, per the corresponding docs/setup/*.md guide) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/v1/storage/google-drive/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/v1/storage/onedrive/callback

DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/v1/storage/dropbox/callback
