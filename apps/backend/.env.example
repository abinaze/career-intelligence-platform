APP_NAME="Career Intelligence Platform"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8000
SECRET_KEY=dev-secret-key-change-in-production-must-be-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://cip_user:cip_password@localhost:5432/cip_db
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MODEL_CACHE_DIR=.model_cache
FAISS_INDEX_PATH=data/faiss/career_index.faiss

# ── Chat (optional) ────────────────────────────────────────────────────────
# Required only for the AI career chat feature (/api/v1/chat/message).
# Without this key, the chat endpoint returns HTTP 503 and the rest of the
# platform works normally. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
